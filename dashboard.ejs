<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    .desc-clamp {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-100 via-pink-50 to-orange-100 text-gray-800">

  <nav class="bg-white/80 backdrop-blur-md border-b border-white/30 px-6 py-4 flex justify-between items-center sticky top-0 z-50">
    <div>
      <h1 class="text-2xl font-extrabold text-gray-800">Hallo Admin</h1>
      <p class="text-sm text-gray-500">Kelola data wisata dengan tampilan yang lebih rapi</p>
    </div>

    <div class="flex gap-3">
      <a href="/admin/tambah"
        class="bg-gradient-to-r from-purple-500 via-pink-500 to-orange-400 text-white px-5 py-2.5 rounded-full font-semibold shadow-md hover:scale-[1.03] hover:shadow-lg transition duration-200">
        + Tambah Wisata
      </a>

      <a href="/admin/logout"
        class="bg-gradient-to-r from-gray-700 to-gray-900 text-white px-5 py-2.5 rounded-full font-semibold shadow-md hover:opacity-90 transition duration-200">
        Logout
      </a>
    </div>
  </nav>

  <main class="p-6 max-w-7xl mx-auto">
    <div class="mb-6">
      <h2 class="text-3xl font-extrabold text-gray-800 mb-2">Data Tempat Wisata</h2>
      <p class="text-gray-600">Pilih kategori untuk melihat data yang sudah dikelompokkan.</p>
    </div>

    <!-- Filter kategori -->
    <div class="flex flex-wrap gap-3 mb-8">
      <button class="filter-btn px-5 py-2.5 rounded-full font-medium transition shadow-sm bg-gradient-to-r from-purple-500 via-pink-500 to-orange-400 text-white"
        data-filter="Semua">
        Semua
      </button>

      <button class="filter-btn px-5 py-2.5 rounded-full font-medium transition bg-white/70 backdrop-blur border border-gray-200 hover:bg-white"
        data-filter="Pantai">
        Pantai
      </button>

      <button class="filter-btn px-5 py-2.5 rounded-full font-medium transition bg-white/70 backdrop-blur border border-gray-200 hover:bg-white"
        data-filter="Caffe">
        Caffe
      </button>

      <button class="filter-btn px-5 py-2.5 rounded-full font-medium transition bg-white/70 backdrop-blur border border-gray-200 hover:bg-white"
        data-filter="Taman">
        Taman
      </button>

      <button class="filter-btn px-5 py-2.5 rounded-full font-medium transition bg-white/70 backdrop-blur border border-gray-200 hover:bg-white"
        data-filter="Alam">
        Alam
      </button>

      <button class="filter-btn px-5 py-2.5 rounded-full font-medium transition bg-white/70 backdrop-blur border border-gray-200 hover:bg-white"
        data-filter="Lainnya">
        Lainnya
      </button>
    </div>

    <div id="wisataContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% if (wisata.length > 0) { %>
        <% wisata.forEach(function(item) { %>
          <div
            class="wisata-card bg-white/80 backdrop-blur-lg rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition duration-300 border border-white/40"
            data-category="<%= item.kategori %>">

            <div class="relative">
              <img
                src="<%= item.gambar %>"
                alt="<%= item.nama %>"
                class="w-full h-56 object-cover"
              />
            </div>

            

            <div class="p-4 flex flex-col justify-between min-h-[240px]">
              <div>
                <h3 class="text-xl font-bold leading-snug text-gray-900">
                  <%= item.nama %>
                </h3>

                <p class="text-sm text-gray-500 mt-1">
                  <%= item.lokasi %>
                </p>

                <% if (item.harga && item.harga.trim() !== "") { %>
                  <p class="text-sm font-semibold text-pink-600 mt-2">
                    Harga: <%= item.harga %>
                  </p>
                <% } %>

                <p class="text-sm text-gray-600 mt-2 desc-clamp">
                  <%= item.deskripsi %>
                </p>

                <p class="text-sm font-medium text-gray-700 mt-2">
                  ❤️ <%= item.like || 0 %> Like
                </p>
              </div>

              <div class="mt-4 flex gap-2">
                <a href="/admin/edit/<%= item._id %>"
                  class="bg-gradient-to-r from-yellow-400 to-orange-400 text-white px-3 py-2 rounded-lg hover:scale-105 transition duration-200">
                  Edit
                </a>

                <a href="/admin/hapus/<%= item._id %>"
                  class="bg-gradient-to-r from-pink-500 to-red-500 text-white px-3 py-2 rounded-lg hover:scale-105 transition duration-200"
                  onclick="return confirm('Yakin ingin menghapus data ini?')">
                  Hapus
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-gray-500">Belum ada data wisata.</p>
      <% } %>
    </div>

    <p id="emptyMessage" class="hidden text-center text-gray-500 text-lg mt-10">
      Tidak ada data wisata pada kategori ini.
    </p>
  </main>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.wisata-card');
    const emptyMessage = document.getElementById('emptyMessage');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        let visibleCount = 0;

        buttons.forEach(btn => {
          btn.classList.remove('bg-gradient-to-r', 'from-purple-500', 'via-pink-500', 'to-orange-400', 'text-white');
          btn.classList.add('bg-white/70', 'border', 'border-gray-200');
        });

        button.classList.remove('bg-white/70', 'border', 'border-gray-200');
        button.classList.add('bg-gradient-to-r', 'from-purple-500', 'via-pink-500', 'to-orange-400', 'text-white');

        cards.forEach(card => {
          const category = card.dataset.category ? card.dataset.category.trim() : '';

          if (filter === 'Semua' || category === filter) {
            card.style.display = 'block';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        if (visibleCount === 0) {
          emptyMessage.classList.remove('hidden');
        } else {
          emptyMessage.classList.add('hidden');
        }
      });
    });
  </script>

</body>
</html>