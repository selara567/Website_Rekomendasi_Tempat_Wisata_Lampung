<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= wisata.nama %> | Detail Wisata</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8f1f5] text-gray-800">

  <div class="max-w-7xl mx-auto px-4 py-8">
    <a
      href="/"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-gradient-to-r from-purple-500 to-orange-400 text-white font-semibold shadow-md hover:opacity-90 transition mb-6"
    >
      <span>←</span>
      <span>Kembali</span>
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-[28px] shadow-sm overflow-hidden relative">
          <img
            id="sliderImage"
            src="<%= wisata.gambar %>"
            alt="<%= wisata.nama %>"
            class="w-full h-[280px] sm:h-[400px] lg:h-[460px] object-cover transition-all duration-700"
          />

          <button
            id="likeButton"
            data-id="<%= wisata._id %>"
            class="absolute top-5 right-5 w-14 h-14 rounded-full bg-white shadow-md flex items-center justify-center text-2xl hover:scale-105 transition"
          >
            <span id="loveIcon" class="<%= isLiked ? 'text-pink-500' : 'text-gray-500' %>">
              <%= isLiked ? "♥" : "♡" %>
            </span>
          </button>
        </div>

        <div class="bg-white rounded-[28px] shadow-sm p-6 sm:p-8">
          <h1 class="text-4xl sm:text-5xl font-bold mb-5">
            <%= wisata.nama %>
          </h1>

          <div class="mb-6">
            <p class="text-sm text-gray-500 mb-1">Lokasi</p>
            <p class="text-gray-700 leading-7">
              <%= wisata.lokasi %>
            </p>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <h2 class="text-xl font-bold mb-3">Tentang tempat ini</h2>
            <p class="text-gray-600 leading-8 text-justify">
              <%= wisata.deskripsi %>
            </p>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="bg-white rounded-[28px] shadow-sm p-6">
          <h2 class="text-2xl font-bold mb-5">Informasi Harga</h2>

          <% if (wisata.hargaTiket) { %>
            <div class="pb-4 mb-4 border-b border-gray-100">
              <p class="text-sm text-gray-500 mb-1">Harga Tiket</p>
              <p class="text-2xl font-bold text-gray-800">
                <%= wisata.hargaTiket %>
              </p>
            </div>
          <% } %>

          <% if (wisata.hargaMakanan) { %>
            <div>
              <p class="text-sm text-gray-500 mb-1">Harga Makanan</p>
              <p class="text-xl font-semibold text-gray-800">
                <%= wisata.hargaMakanan %>
              </p>
            </div>
          <% } %>

          <% if (!wisata.hargaTiket && !wisata.hargaMakanan) { %>
            <p class="text-gray-500">Informasi harga belum tersedia.</p>
          <% } %>
        </div>

        <div class="bg-white rounded-[28px] shadow-sm p-6">
          <h2 class="text-2xl font-bold mb-5">Info Singkat</h2>

          <div class="space-y-5">
            <div>
              <p class="text-sm text-gray-500">Kategori</p>
              <p class="font-semibold text-gray-800"><%= wisata.kategori %></p>
            </div>

            <div>
              <p class="text-sm text-gray-500">Lokasi</p>
              <p class="text-gray-700 leading-7"><%= wisata.lokasi %></p>
            </div>

            <div>
              <p class="text-sm text-gray-500">Popularitas</p>
              <p class="font-semibold text-gray-800">
                <span id="likeCountSide"><%= wisata.like %></span> like
              </p>
            </div>
          </div>

          <% if (wisata.mapsLink) { %>
            <a
              href="<%= wisata.mapsLink %>"
              target="_blank"
              class="mt-6 inline-flex w-full items-center justify-center px-5 py-3.5 rounded-2xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-semibold hover:opacity-90 transition"
            >
              Lihat di Maps
            </a>
          <% } %>
        </div>

        <div class="pt-2">
          <p class="text-gray-700 text-lg font-semibold mb-4">
            Ingin menambahkan tempat wisata?
          </p>

          <div class="flex flex-col gap-3">
            <a
              href="https://wa.me/6288287255095"
              target="_blank"
              class="block w-full rounded-2xl bg-white px-5 py-4 text-base font-semibold text-green-600 shadow-sm hover:shadow-md hover:scale-[1.01] transition"
            >
              WhatsApp: 088287255095
            </a>

            <a
              href="mailto:admin@wisata.com"
              class="block w-full rounded-2xl bg-white px-5 py-4 text-base font-semibold text-blue-600 shadow-sm hover:shadow-md hover:scale-[1.01] transition"
            >
              Email: admin@wisata.com
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    const likeButton = document.getElementById("likeButton");
    const loveIcon = document.getElementById("loveIcon");
    const likeCountSide = document.getElementById("likeCountSide");

    likeButton.addEventListener("click", async () => {
      const id = likeButton.dataset.id;

      try {
        const response = await fetch(`/like/${id}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" }
        });

        const data = await response.json();

        if (data.success) {
          loveIcon.textContent = data.liked ? "♥" : "♡";
          loveIcon.className = data.liked ? "text-pink-500" : "text-gray-500";
          likeCountSide.textContent = data.like;
        }
      } catch (error) {
        console.log(error);
      }
    });
  </script>


</body>
</html>